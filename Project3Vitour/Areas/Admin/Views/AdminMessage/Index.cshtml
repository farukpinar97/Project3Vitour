@* ===== Areas/Admin/Views/AdminMessage/Index.cshtml ===== *@
@using Project3Vitour.Entities
@model List<ContactMessage>
@{
    ViewBag.Title = "Mesajlar";
    ViewBag.ActiveMenu = "messages";
    int unreadCount = ViewBag.UnreadCount ?? 0;
    int totalCount = ViewBag.TotalCount ?? 0;
}

<style>
    .message-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .message-stat {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: var(--shadow);
    }

    .message-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .message-stat-value {
        font-size: 22px;
        font-weight: 800;
        line-height: 1;
    }

    .message-stat-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 500;
        margin-top: 3px;
    }

    .message-row {
        cursor: pointer;
        transition: background .15s;
    }

        .message-row.unread {
            background: #f0faf5;
        }

            .message-row.unread td:first-child {
                border-left: 3px solid var(--primary);
            }

        .message-row:hover {
            background: var(--primary-bg) !important;
        }

    .unread-dot {
        width: 8px;
        height: 8px;
        background: var(--primary);
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }

    .filter-tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 16px;
    }

    .filter-tab {
        padding: 6px 16px;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: transparent;
        font-size: 12.5px;
        font-weight: 600;
        cursor: pointer;
        color: var(--text-muted);
        transition: all .2s;
        font-family: inherit;
        text-decoration: none;
        display: inline-block;
    }

        .filter-tab.active {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .filter-tab:hover:not(.active) {
            border-color: var(--primary);
            color: var(--primary);
        }

    .message-preview {
        max-width: 280px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--text-muted);
        font-size: 13px;
    }
</style>

<!-- İstatistik Kartları -->
<div class="message-stats">
    <div class="message-stat">
        <div class="message-stat-icon" style="background:#dbeafe; color:#2563eb;">
            <i class="fa-solid fa-envelope"></i>
        </div>
        <div>
            <div class="message-stat-value">@totalCount</div>
            <div class="message-stat-label">Toplam Mesaj</div>
        </div>
    </div>
    <div class="message-stat">
        <div class="message-stat-icon" style="background:#fef3c7; color:#d97706;">
            <i class="fa-solid fa-envelope-open"></i>
        </div>
        <div>
            <div class="message-stat-value">@unreadCount</div>
            <div class="message-stat-label">Okunmamış</div>
        </div>
    </div>
    <div class="message-stat">
        <div class="message-stat-icon" style="background:#dcfce7; color:#16a34a;">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <div>
            <div class="message-stat-value">@(totalCount - unreadCount)</div>
            <div class="message-stat-label">Okunmuş</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">
            <i class="fa-solid fa-inbox" style="color:var(--primary);margin-right:8px;"></i>
            Gelen Kutusu
            @if (unreadCount > 0)
            {
                <span class="badge badge-red" style="margin-left:8px;">@unreadCount yeni</span>
            }
        </span>
        <div class="flex gap-2">
            <div class="search-box" style="min-width:220px;">
                <i class="fa-solid fa-search"></i>
                <input type="text" class="form-control" placeholder="Mesajlarda ara..." id="msgSearch">
            </div>
        </div>
    </div>

    <div class="card-body" style="padding-bottom:0; padding-top:16px;">
        <div class="filter-tabs">
            <a href="?filter=all&page=1" class="filter-tab @(ViewBag.CurrentFilter == "all" || ViewBag.CurrentFilter == null ? "active" : "")">
                Tümü (@(ViewBag.TotalCount ?? 0))
            </a>
            <a href="?filter=unread&page=1" class="filter-tab @(ViewBag.CurrentFilter == "unread" ? "active" : "")">
                Okunmamış (@(ViewBag.UnreadCount ?? 0))
            </a>
            <a href="?filter=read&page=1" class="filter-tab @(ViewBag.CurrentFilter == "read" ? "active" : "")">
                Okunmuş (@((ViewBag.TotalCount ?? 0) - (ViewBag.UnreadCount ?? 0)))
            </a>
        </div>

    <div class="table-wrap">
        <table id="msgTable">
            <thead>
                <tr>
                    <th style="width:8px;"></th>
                    <th>Gönderen</th>
                    <th>E-posta</th>
                    <th>Mesaj Önizleme</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="message-row @(!item.IsRead ? "unread" : "")"
                        data-read="@item.IsRead.ToString().ToLower()"
                        onclick="window.location='/Admin/AdminMessage/Detail/@item.MessageID'">
                        <td>
                            @if (!item.IsRead)
                            {
                                <span class="unread-dot"></span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div style="width:36px; height:36px; border-radius:50%; background:var(--primary-bg); color:var(--primary); font-weight:700; font-size:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                    @item.FullName?.Substring(0, 1).ToUpper()
                                </div>
                                <span class="fw-600">@item.FullName</span>
                            </div>
                        </td>
                        <td class="text-muted">@item.Email</td>
                        <td>
                            <div class="message-preview">@item.Message</div>
                        </td>
                        <td class="text-muted" style="white-space:nowrap;">
                            <div>@item.CreatedAt.ToString("dd MMM yyyy")</div>
                            <div style="font-size:11px;">@item.CreatedAt.ToString("HH:mm")</div>
                        </td>
                        <td onclick="event.stopPropagation()">
                            @if (!item.IsRead)
                            {
                                <span class="badge badge-amber">
                                    <i class="fa-solid fa-circle" style="font-size:7px;"></i> Okunmamış
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-gray">
                                    <i class="fa-solid fa-circle" style="font-size:7px;"></i> Okunmuş
                                </span>
                            }
                        </td>
                        <td onclick="event.stopPropagation()">
                            <div class="flex gap-2">
                                <a asp-area="Admin" asp-controller="AdminMessage" asp-action="Detail"
                                   asp-route-id="@item.MessageID"
                                   class="btn btn-outline btn-sm btn-icon" title="Görüntüle">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                @if (!item.IsRead)
                                {
                                    <a asp-area="Admin" asp-controller="AdminMessage" asp-action="MarkAsRead"
                                       asp-route-id="@item.MessageID"
                                       class="btn btn-outline btn-sm btn-icon" title="Okundu işaretle">
                                        <i class="fa-solid fa-check" style="color:var(--primary);"></i>
                                    </a>
                                }
                                <a asp-area="Admin" asp-controller="AdminMessage" asp-action="Delete"
                                   asp-route-id="@item.MessageID"
                                   class="btn btn-danger btn-sm btn-icon" title="Sil"
                                   onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?')">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
            @{
                int currentPage = ViewBag.CurrentPage ?? 1;
                int totalPages = ViewBag.TotalPages ?? 1;
                string currentFilter = ViewBag.CurrentFilter ?? "all";
            }

            @if (totalPages > 1)
            {
                <div style="display:flex; justify-content:center; align-items:center; gap:8px; padding:20px;">
                    @if (currentPage > 1)
                    {
                        <a href="?filter=@currentFilter&page=@(currentPage - 1)" class="btn btn-outline btn-sm">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        string pageUrl = $"?filter={currentFilter}&page={i}";
                        bool isActive = i == currentPage;
                        <a href="@pageUrl"
                           class="btn btn-sm @(isActive ? "" : "btn-outline")"
                           style="@(isActive ? "background:var(--primary); color:white; border-color:var(--primary);" : "")">
                            @i
                        </a>
                    }

                    @if (currentPage < totalPages)
                    {
                        <a href="?filter=@currentFilter&page=@(currentPage + 1)" class="btn btn-outline btn-sm">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    }
                </div>
            }

        @if (!Model.Any())
        {
            <div style="text-align:center; padding:56px; color:var(--text-muted);">
                <i class="fa-solid fa-inbox" style="font-size:40px; margin-bottom:14px; display:block; opacity:.2;"></i>
                <div style="font-size:15px; font-weight:600; margin-bottom:6px;">Gelen kutunuz boş</div>
                <div style="font-size:13px;">Henüz mesaj almadınız.</div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Arama
        document.getElementById('msgSearch').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#msgTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>
}
