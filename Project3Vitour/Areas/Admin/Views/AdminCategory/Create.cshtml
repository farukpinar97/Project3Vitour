@using Project3Vitour.Dtos.CategoryDtos
@model CreateCategoryDto
@{
    ViewBag.Title = "Yeni Kategori";
    ViewBag.ActiveMenu = "categories";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <span class="card-title">
                    <i class="fa-solid fa-tag" style="color:var(--primary); margin-right:8px;"></i>
                    Yeni Kategori Ekle
                </span>
                <a asp-area="Admin" asp-controller="AdminCategory" asp-action="Index" class="btn btn-outline btn-sm">
                    <i class="fa-solid fa-arrow-left"></i> Geri
                </a>
            </div>
            <div class="card-body" style="padding:30px;">
                <form asp-action="Create" asp-controller="AdminCategory" asp-area="Admin" method="post">
                    <div style="margin-bottom:20px;">
                        <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">
                            Kategori Adı <span style="color:#ef4444;">*</span>
                        </label>
                        <input type="text" name="CategoryName" class="form-control"
                               placeholder="Kategori adını girin..." required>
                    </div>
                    <div style="margin-bottom:28px;">
                        <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">Durum</label>
                        <div style="display:flex; gap:16px;">
                            <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                                <input type="radio" name="CategoryStatus" value="true" checked> Aktif
                            </label>
                            <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                                <input type="radio" name="CategoryStatus" value="false"> Pasif
                            </label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;">
                        <i class="fa-solid fa-check"></i> Kategori Ekle
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>