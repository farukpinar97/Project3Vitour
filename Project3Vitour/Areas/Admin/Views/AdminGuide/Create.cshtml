@using Project3Vitour.Dtos.GuideDtos
@model CreateGuideDto
@{
    ViewBag.Title = "Yeni Rehber Ekle";
    ViewBag.ActiveMenu = "guides";
}

<style>
    .social-input-wrap {
        position: relative;
    }

        .social-input-wrap .social-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 20px;
            height: 20px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            color: #fff;
        }

        .social-input-wrap input {
            padding-left: 40px;
        }

    .image-preview-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--border);
        display: block;
        margin: 0 auto 12px;
    }

    .avatar-placeholder {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: var(--primary-bg);
        border: 3px dashed var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-size: 32px;
        color: var(--text-muted);
    }

    .toggle-switch {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: var(--bg);
        border-radius: 8px;
        border: 1.5px solid var(--border);
        cursor: pointer;
    }

        .toggle-switch input {
            display: none;
        }

    .toggle-track {
        width: 44px;
        height: 24px;
        background: var(--border);
        border-radius: 12px;
        position: relative;
        transition: background .3s;
        flex-shrink: 0;
    }

    .toggle-thumb {
        width: 18px;
        height: 18px;
        background: #fff;
        border-radius: 50%;
        position: absolute;
        top: 3px;
        left: 3px;
        transition: transform .3s;
        box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }

    .toggle-switch input:checked ~ .toggle-track {
        background: var(--primary);
    }

        .toggle-switch input:checked ~ .toggle-track .toggle-thumb {
            transform: translateX(20px);
        }

    .toggle-label {
        font-size: 13.5px;
        font-weight: 600;
        flex: 1;
    }

    .toggle-desc {
        font-size: 11.5px;
        color: var(--text-muted);
    }
</style>

<form asp-area="Admin" asp-controller="AdminGuide" asp-action="Create" method="post">
    <div class="grid-2" style="align-items:start; gap:20px;">

        <!-- Sol: Kişisel Bilgiler -->
        <div style="display:flex; flex-direction:column; gap:20px;">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="fa-solid fa-user" style="color:var(--primary);margin-right:8px;"></i>
                        Kişisel Bilgiler
                    </span>
                </div>
                <div class="card-body">
                    <div class="form-grid cols-1">
                        <div class="form-group">
                            <label class="form-label">Ad Soyad <span>*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Ör: Ahmet Yılmaz" required
                                   id="fullNameInput" oninput="updateAvatarLetter()">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Unvan <span>*</span></label>
                            <select asp-for="Title" class="form-control" required>
                                <option value="">-- Unvan Seçin --</option>
                                <option value="Kıdemli Tur Rehberi">Kıdemli Tur Rehberi</option>
                                <option value="Tur Rehberi">Tur Rehberi</option>
                                <option value="Kültür & Tarih Rehberi">Kültür & Tarih Rehberi</option>
                                <option value="Doğa & Macera Rehberi">Doğa & Macera Rehberi</option>
                                <option value="Gastronomi Turu Rehberi">Gastronomi Turu Rehberi</option>
                                <option value="Uluslararası Tur Rehberi">Uluslararası Tur Rehberi</option>
                                <option value="Şehir Turu Rehberi">Şehir Turu Rehberi</option>
                                <option value="Dağ & Yayla Rehberi">Dağ & Yayla Rehberi</option>
                                <option value="VIP Özel Tur Rehberi">VIP Özel Tur Rehberi</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sosyal Medya -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="fa-solid fa-share-nodes" style="color:var(--primary);margin-right:8px;"></i>
                        Sosyal Medya
                    </span>
                </div>
                <div class="card-body">
                    <div class="form-grid cols-1">
                        <div class="form-group">
                            <label class="form-label">Facebook</label>
                            <div class="social-input-wrap">
                                <span class="social-icon" style="background:#1877f2;">
                                    <i class="fa-brands fa-facebook-f"></i>
                                </span>
                                <input asp-for="Facebook" class="form-control" placeholder="https://facebook.com/kullanici">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Instagram</label>
                            <div class="social-input-wrap">
                                <span class="social-icon" style="background:linear-gradient(45deg,#f09433,#dc2743,#bc1888);">
                                    <i class="fa-brands fa-instagram"></i>
                                </span>
                                <input asp-for="Instagram" class="form-control" placeholder="https://instagram.com/kullanici">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">LinkedIn</label>
                            <div class="social-input-wrap">
                                <span class="social-icon" style="background:#0a66c2;">
                                    <i class="fa-brands fa-linkedin-in"></i>
                                </span>
                                <input asp-for="LinkedIn" class="form-control" placeholder="https://linkedin.com/in/kullanici">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">YouTube</label>
                            <div class="social-input-wrap">
                                <span class="social-icon" style="background:#ff0000;">
                                    <i class="fa-brands fa-youtube"></i>
                                </span>
                                <input asp-for="YouTube" class="form-control" placeholder="https://youtube.com/kanal">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ: Fotoğraf & Durum -->
        <div style="display:flex; flex-direction:column; gap:20px;">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="fa-solid fa-image" style="color:var(--primary);margin-right:8px;"></i>
                        Profil Fotoğrafı
                    </span>
                </div>
                <div class="card-body" style="text-align:center;">
                    <div id="avatarPlaceholder" class="avatar-placeholder">
                        <span id="avatarLetter" style="font-size:36px; font-weight:700; color:var(--primary);">?</span>
                    </div>
                    <img id="avatarPreview" class="image-preview-circle" src="" alt="" style="display:none;">

                    <div class="form-group" style="text-align:left; margin-top:8px;">
                        <label class="form-label">Fotoğraf URL <span>*</span></label>
                        <div style="display:flex; gap:8px;">
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." id="imageUrl" required>
                            <button type="button" onclick="previewAvatar()" class="btn btn-primary btn-icon" title="Önizle">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div id="previewStatus" style="font-size:12px; margin-top:6px; display:none; color:#16a34a;">
                        <i class="fa-solid fa-circle-check"></i> Görsel yüklendi
                    </div>
                </div>
            </div>

            <!-- Durum -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="fa-solid fa-toggle-on" style="color:var(--primary);margin-right:8px;"></i>
                        Durum
                    </span>
                </div>
                <div class="card-body">
                    <label class="toggle-switch" for="statusToggle">
                        <input type="checkbox" id="statusToggle" name="Status" value="true" checked>
                        <div class="toggle-track"><div class="toggle-thumb"></div></div>
                        <div>
                            <div class="toggle-label" id="statusLabel">Aktif</div>
                            <div class="toggle-desc">Rehber sitede görünür olacak</div>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Önizleme Kartı -->
            <div class="card" style="border:2px solid var(--primary-bg);">
                <div class="card-header" style="background:var(--primary-bg);">
                    <span class="card-title" style="color:var(--primary);">
                        <i class="fa-solid fa-eye" style="margin-right:8px;"></i>Kart Önizleme
                    </span>
                </div>
                <div class="card-body" style="text-align:center;">
                    <img id="cardPreviewImg" src="" alt=""
                         style="width:70px; height:70px; border-radius:50%; object-fit:cover; border:3px solid var(--border); display:none; margin:0 auto 10px;">
                    <div id="cardPreviewInitial"
                         style="width:70px; height:70px; border-radius:50%; background:var(--primary); color:#fff; font-size:24px; font-weight:700; display:flex; align-items:center; justify-content:center; margin:0 auto 10px;">
                        ?
                    </div>
                    <div id="cardPreviewName" style="font-weight:700; font-size:15px; margin-bottom:4px;">Ad Soyad</div>
                    <div id="cardPreviewTitle" style="font-size:12px; color:var(--text-muted);">Unvan</div>
                    <div style="display:flex; justify-content:center; gap:6px; margin-top:12px;" id="cardSocials">
                        <span style="font-size:11px; color:var(--text-muted);">Sosyal medya burada gösterilecek</span>
                    </div>
                </div>
            </div>

            <!-- Kaydet -->
            <div class="card">
                <div class="card-body">
                    <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:11px;">
                        <i class="fa-solid fa-plus"></i> Rehberi Ekle
                    </button>
                    <a asp-area="Admin" asp-controller="AdminGuide" asp-action="Index"
                       class="btn btn-outline mt-4" style="width:100%; justify-content:center;">
                        <i class="fa-solid fa-arrow-left"></i> Geri Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Avatar harf güncelle
        function updateAvatarLetter() {
            const name = document.getElementById('fullNameInput').value.trim();
            const letter = name ? name.charAt(0).toUpperCase() : '?';
            document.getElementById('avatarLetter').textContent = letter;
            document.getElementById('cardPreviewInitial').textContent = letter;
            document.getElementById('cardPreviewName').textContent = name || 'Ad Soyad';
        }

        // Unvan önizleme
        document.querySelector('[name="Title"]').addEventListener('change', function () {
            document.getElementById('cardPreviewTitle').textContent = this.value || 'Unvan';
        });

        // Fotoğraf önizleme
        function previewAvatar() {
            const url = document.getElementById('imageUrl').value.trim();
            if (!url) return;
            const img = document.getElementById('avatarPreview');
            const cardImg = document.getElementById('cardPreviewImg');
            img.src = url;
            img.onload = () => {
                document.getElementById('avatarPlaceholder').style.display = 'none';
                img.style.display = 'block';
                document.getElementById('previewStatus').style.display = 'block';
                cardImg.src = url;
                cardImg.style.display = 'block';
                document.getElementById('cardPreviewInitial').style.display = 'none';
            };
            img.onerror = () => alert('Görsel yüklenemedi. URL\'yi kontrol edin.');
        }

        document.getElementById('imageUrl').addEventListener('change', function () {
            if (this.value.trim()) previewAvatar();
        });

        // Durum toggle
        document.getElementById('statusToggle').addEventListener('change', function () {
            document.getElementById('statusLabel').textContent = this.checked ? 'Aktif' : 'Pasif';
        });
    </script>
}
