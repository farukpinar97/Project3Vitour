@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<section class="widget-faq pd-main">
    <div class="tf-container">
        <div class="row">
            <div class="col-md-6">
                <div class="image-faq">
                    <img src="https://themesflat.co/html/vitour/assets/images/page/travel_facebook.png" alt="görsel">
                </div>
            </div>
            <div class="col-md-6">
                <div class="content-faq">
                    <div class="mb-50">
                        <span class="sub-title-heading text-main font-yes fs-28-46 wow fadeInUp animated">
                            @Localizer["Faq_Explore"]
                        </span>
                        <h2 class="title-heading wow fadeInUp animated">@Localizer["Faq_Enjoy"]</h2>
                    </div>
                    <div class="accordion faq-list" id="accordionExample">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                        data-bs-target="#collapseOne" aria-expanded="true"
                                        aria-controls="collapseOne">
                                    @Localizer["Faq_ReservationQuestion"]
                                </button>
                            </h2>
                            <div id="collapseOne" class="accordion-collapse collapse relative show"
                                 data-bs-parent="#accordionExample">
                                <div class="accordion-body">
                                    @Localizer["Faq_ReservationAnswer"]
                                </div>
                                <div class="icon"></div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseTwo"
                                        aria-expanded="false" aria-controls="collapseTwo">
                                    @Localizer["Faq_IncludedQuestion"]
                                </button>
                            </h2>
                            <div id="collapseTwo" class="accordion-collapse relative collapse"
                                 data-bs-parent="#accordionExample">
                                <div class="accordion-body">
                                    @Localizer["Faq_IncludedAnswer"]
                                </div>
                                <div class="icon"></div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseThree"
                                        aria-expanded="false" aria-controls="collapseThree">
                                    @Localizer["Faq_CancelQuestion"]
                                </button>
                            </h2>
                            <div id="collapseThree" class="accordion-collapse relative collapse"
                                 data-bs-parent="#accordionExample">
                                <div class="accordion-body">
                                    @Localizer["Faq_CancelAnswer"]
                                </div>
                                <div class="icon"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>