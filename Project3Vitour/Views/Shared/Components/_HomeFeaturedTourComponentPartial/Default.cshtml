@using Project3Vitour.Dtos.TourDtos
@model List<ResultTourDto>

<section class="tour-package2">
    <div class="tf-container">
        <div class="row">
            <div class="col-lg-12">
                <div class="mb-30 center">
                    <span class="sub-title-heading text-main font-yes fs-28-46 wow fadeInUp animated">
                        Dünyayı Keşfet
                    </span>
                    <h2 class="title-heading wow fadeInUp animated">Öne Çıkan Turlarımız</h2>
                </div>
            </div>
        </div>
        <div class="row mb-15">
            <div class="col-lg-12 relative tour-package-swipper-wrap">
                <div class="swiper tour-package-swipper overflow-hidden relative">
                    <div class="swiper-wrapper">
                        @foreach (var item in Model)
                        {
                            <div class="swiper-slide">
                                <div class="tour-listing box-sd">
                                    <a href="/Tour/TourDetail/@item.TourID" class="tour-listing-image">
                                        <div class="badge-top flex-two">
                                            <span class="feature bg-2">@item.Badge</span>
                                            <div class="badge-media flex-five">
                                                <span class="media">
                                                    <i class="icon-Group-1000002909"></i>@item.GalleryImages?.Count
                                                </span>
                                            </div>
                                        </div>
                                        <img src="@item.CoverImageUrl" alt="@item.Title"
                                             style="width:100%; height:220px; object-fit:cover;">
                                    </a>
                                    <div class="tour-listing-content">
                                        <span class="map">
                                            <i class="icon-Vector4"></i>
                                            @(string.IsNullOrEmpty(item.Location) ? "Konum belirtilmemiş" : item.Location)
                                        </span>
                                        <h3 class="title-tour-list">
                                            <a href="/Tour/TourDetail/@item.TourID">@item.Title</a>
                                        </h3>
                                        <div class="review">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= Math.Round(item.AverageRating))
                                                {
                                                    <i class="icon-Star" style="color:#f59e0b;"></i>
                                                }
                                                else
                                                {
                                                    <i class="icon-Star" style="color:#d1d5db;"></i>
                                                }
                                            }
                                            <span>
                                                @if (item.ReviewCount > 0)
                                                {
                                                    @($"({item.AverageRating:F1} | {item.ReviewCount} Değerlendirme)")
                                                }
                                                else
                                                {
                                                    @("(Değerlendirme yok)")
                                                }
                                            </span>
                                        </div>
                                        <div class="icon-box flex-three">
                                            <div class="icons flex-three">
                                                <i class="icon-time-left"></i>
                                                <span>@item.DayCount Gün</span>
                                            </div>
                                            <div class="icons flex-three">
                                                <svg width="21" height="16" viewBox="0 0 21 16" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M4.34766 4.79761C4.34766 2.94013 5.85346 1.43433 7.71094 1.43433C9.56841 1.43433 11.0742 2.94013 11.0742 4.79761C11.0742 6.65508 9.56841 8.16089 7.71094 8.16089C5.85346 8.16089 4.34766 6.65508 4.34766 4.79761Z"
                                                          stroke="currentColor" stroke-width="1.7"
                                                          stroke-miterlimit="10" stroke-linecap="round"
                                                          stroke-linejoin="round" />
                                                    <path d="M9.5977 15.1797H2.46098C1.34827 15.1797 0.558268 14.0954 0.898984 13.0362C1.80408 10.222 4.57804 8.18566 7.69301 8.18566C9.17897 8.18566 10.5566 8.64906 11.6895 9.43922"
                                                          stroke="currentColor" stroke-width="1.7"
                                                          stroke-miterlimit="10" stroke-linecap="round"
                                                          stroke-linejoin="round" />
                                                    <path d="M17.1035 15.1797V9.02734" stroke="currentColor"
                                                          stroke-width="1.7" stroke-miterlimit="10"
                                                          stroke-linecap="round" stroke-linejoin="round" />
                                                    <path d="M20.1797 12.1035H14.0273" stroke="currentColor"
                                                          stroke-width="1.7" stroke-miterlimit="10"
                                                          stroke-linecap="round" stroke-linejoin="round" />
                                                </svg>
                                                <span>@item.Capacity Kişi</span>
                                            </div>
                                        </div>
                                        <div class="flex-two">
                                            <div class="price-box flex-three">
                                                <p>Başlangıç <span class="price-sale">@item.Price ₺</span></p>
                                                <del><span class="price">@(item.Price + item.Price * 20 / 100) ₺</span></del>
                                            </div>
                                            <a href="/Booking/Create?id=@item.TourID" class="icon-bookmark" title="Rezervasyon Yap">
                                                <i class="icon-19"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12 relative">
                <a href="/Tour/TourList/" class="tour-link center flex-five m0-auto z-index3 relative">
                    <span>Tüm Turlar</span>
                    <i class="icon-Group-13"></i>
                </a>
                <div class="line"></div>
            </div>
        </div>
    </div>
</section>