@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<footer class="footer footer-style1">
    <div class="tf-container">
        <div class="footer-main">
            <div class="footer-logo">
                <div class="logo-footer">
                    <img src="/vitour/assets/images/logo2.png" alt="">
                </div>
                <p class="des-footer">
                    @Localizer["Footer_Description"]
                </p>
                <ul class="footer-info">
                    <li class="flex-three">
                        <i class="icon-noun-mail-5780740-1"></i>
                        <p>info@vitour.com</p>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Group-9"></i>
                        <p>+90 212 555 01 02</p>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Layer-19"></i>
                        <p>Bağdat Caddesi No:123 <br />Kadıköy / İstanbul</p>
                    </li>
                </ul>

            </div>
            <div class="footer-service">
                <h5 class="title">@Localizer["Footer_Corporate"]l</h5>

                <ul class="footer-menu">
                    <li>
                        <a href="about-us.html">@Localizer["Footer_AboutUs"]</a>
                    </li>
                    <li>
                        <a href="gallery.html">@Localizer["Footer_Gallery"]</a>
                    </li>
                    <li>
                        <a href="team.html">@Localizer["Footer_Team"]</a>
                    </li>
                    <li>
                        <a href="blog.html">@Localizer["Footer_Blog"]</a>
                    </li>
                    <li>
                        <a href="contact-us.html">@Localizer["Footer_Contact"]</a>
                    </li>
                </ul>
            </div>
            <div class="footer-gallery">
                <h5 class="title">@Localizer["Footer_GalleryTitle"]</h5>

                <div class="gallery-img">
                    <a href="https://themesflat.co/html/vitour/assets/images/gallery/gl1.jpg" data-fancybox="gallery">
                        <img src="https://themesflat.co/html/vitour/assets/images/gallery/gl1.jpg" alt="image gallery">
                    </a>
                    <a href="https://themesflat.co/html/vitour/assets/images/gallery/gl2.jpg" data-fancybox="gallery">
                        <img src="https://themesflat.co/html/vitour/assets/images/gallery/gl2.jpg" alt="image gallery">
                    </a>
                    <a href="https://themesflat.co/html/vitour/assets/images/gallery/gl3.jpg" data-fancybox="gallery">
                        <img src="https://themesflat.co/html/vitour/assets/images/gallery/gl3.jpg" alt="image gallery">
                    </a>
                    <a href="https://themesflat.co/html/vitour/assets/images/gallery/gl4.jpg" data-fancybox="gallery">
                        <img src="https://themesflat.co/html/vitour/assets/images/gallery/gl4.jpg" alt="image gallery">
                    </a>
                    <a href="https://themesflat.co/html/vitour/assets/images/gallery/gl5.jpg" data-fancybox="gallery">
                        <img src="https://themesflat.co/html/vitour/assets/images/gallery/gl5.jpg" alt="image gallery">
                    </a>
                    <a href="https://themesflat.co/html/vitour/assets/images/gallery/gl6.jpg" data-fancybox="gallery">
                        <img src="https://themesflat.co/html/vitour/assets/images/gallery/gl6.jpg" alt="image gallery">
                    </a>
                </div>

            </div>
            <div class="footer-newsletter">
                <h5 class="title">@Localizer["Footer_Newsletter"]</h5>
                <form action="/" id="footer-form">
                    <div class="input-wrap flex-three">
                        <input type="email" placeholder="@Localizer["Footer_Newsletter_Placeholder"]">
                        <button type="submit"><i class="icon-paper-plane"></i></button>
                    </div>
                    <div class="check-form flex-three">
                        <i class="icon-Vector-121"></i>
                        <p>@Localizer["Footer_Newsletter_Checkbox"]</p>
                    </div>
                </form>
                <ul class="social-ft flex-three">
                    <li>
                        <a href="#">
                            <i class="icon-icon-2"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-x"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-8"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-2"></i>
                        </a>
                    </li>
                </ul>

            </div>
        </div>

        <div class="row footer-bottom">
            <div class="col-md-6">
                <p class="copy-right">@DateTime.Now.Year | @Localizer["Footer_Copyright"]</p>
            </div>
            <div class="col-md-6">
                <ul class="social flex-six">
                    <li>
                        <a href="#">
                            <i class="icon-icon-2"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-x"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-icon_03"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-2"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</footer>