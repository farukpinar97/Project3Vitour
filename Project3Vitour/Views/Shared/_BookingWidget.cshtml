@model Project3Vitour.Dtos.TourDtos.GetTourByIdDto
<div class="side-bar-right">
    <div class="sidebar-widget">
        <h6 class="block-heading">Bu Turu Rezerve Et</h6>
        <div class="flex-two mb-40">
            <span class="label">Fiyat:</span>
            <span class="total text-main">@Model.Price ₺</span>
        </div>
        <button onclick="window.location.href='/Booking/Create?id=@Model.TourID'"
                class="tf-btn btn-fill"
                style="width:100%; text-align:center; display:block; padding:14px; border:none; cursor:pointer;">
            <i class="icon-Vector-7"></i> Hemen Rezervasyon Yap
        </button>
    </div>
    <div class="sidebar-widget">
        <h6 class="block-heading">Güvenle Rezerve Edin</h6>
        <ul class="category-confidence">
            <li class="flex-three">
                <i class="icon-customer-service-1"></i>
                <span>7/24 Müşteri Desteği</span>
            </li>
            <li class="flex-three">
                <i class="icon-Vector-6"></i>
                <span>Özenle Seçilmiş Turlar</span>
            </li>
            <li class="flex-three">
                <i class="icon-insurance-1"></i>
                <span>Ücretsiz Seyahat Sigortası</span>
            </li>
            <li class="flex-three">
                <i class="icon-price-tag-1-1"></i>
                <span>En İyi Fiyat Garantisi</span>
            </li>
        </ul>
    </div>
</div>