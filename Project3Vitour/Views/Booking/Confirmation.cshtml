@{
    ViewBag.Title = "Rezervasyon Onayı";
}
<section style="padding:80px 0;">
    <div class="tf-container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div style="background:#fff; border-radius:16px; padding:60px 40px; box-shadow:0 2px 20px rgba(0,0,0,.08);">
                    <div style="width:80px; height:80px; background:#dcfce7; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 24px;">
                        <i class="icon-Vector-7" style="font-size:32px; color:#16a34a;"></i>
                    </div>
                    <h3 style="font-size:26px; font-weight:800; margin-bottom:12px;">Rezervasyonunuz Alındı!</h3>
                    <p style="color:#6b7280; margin-bottom:24px; line-height:1.7;">
                        Rezervasyon talebiniz başarıyla alındı. Ekibimiz en kısa sürede
                        <strong>e-posta veya telefon</strong> ile sizinle iletişime geçecek.
                    </p>

                    @if (ViewBag.BookingNumber != null)
                    {
                        <div style="background:#f0fdf4; border:2px dashed #16a34a; border-radius:12px; padding:20px; margin-bottom:24px;">
                            <p style="font-size:13px; color:#6b7280; margin-bottom:6px;">Rezervasyon Numaranız</p>
                            <p style="font-size:24px; font-weight:800; color:#16a34a; letter-spacing:2px;">
                                @ViewBag.BookingNumber
                            </p>
                            <p style="font-size:12px; color:#6b7280; margin-top:6px;">Bu numarayı saklayınız</p>
                        </div>
                    }

                    <div style="background:#f8fafc; border-radius:12px; padding:20px; margin-bottom:32px; text-align:left;">
                        <p style="font-size:13px; color:#6b7280; margin-bottom:4px;">Rezervasyon durumunuzu takip etmek için:</p>
                        <p style="font-size:13px; font-weight:600; color:var(--primary);">Kayıt e-postanızı kontrol edin</p>
                    </div>

                    <div style="display:flex; gap:12px; justify-content:center;">
                        <button onclick="window.location.href='/Tour/TourList'"
                                class="tf-btn btn-fill"
                                style="border:none; cursor:pointer; padding:12px 24px;">
                            Turlara Dön
                        </button>
                        <button onclick="window.location.href='/Tour/TourDetail/@ViewBag.TourId'"
                                style="padding:12px 24px; border:2px solid var(--primary); border-radius:8px; color:var(--primary); font-weight:600; cursor:pointer; background:transparent;">
                            Tura Geri Dön
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>