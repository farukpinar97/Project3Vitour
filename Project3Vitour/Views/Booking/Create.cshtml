@using Project3Vitour.Dtos.TourDtos
@model GetTourByIdDto

@{
    decimal originalPrice = Model.Price + Model.Price * 20 / 100;
    int remaining = ViewBag.RemainingCapacity ?? 0;
    string capacityColor = remaining == 0 ? "#ef4444" : remaining <= 5 ? "#f59e0b" : "#16a34a";
    string capacityText = remaining == 0 ? "Kontenjan Dolu!" : $"{remaining} kişilik yer kaldı";
}

<section class="booking-page" style="padding: 60px 0;">
    <div class="tf-container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div style="background:#fff; border-radius:16px; padding:40px; box-shadow:0 2px 20px rgba(0,0,0,.08);">
                    <h3 style="font-size:24px; font-weight:700; margin-bottom:8px;">Rezervasyon Yap</h3>
                    <p style="color:#6b7280; margin-bottom:32px;">Aşağıdaki formu doldurun, en kısa sürede sizinle iletişime geçelim.</p>

                    @* Hata mesajı *@
                    @if (TempData["Error"] != null)
                    {
                        <div style="background:#fee2e2; color:#ef4444; padding:14px 16px; border-radius:8px; margin-bottom:24px; display:flex; align-items:center; gap:10px;">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            @TempData["Error"]
                        </div>
                    }

                    @* Kontenjan dolu uyarısı *@
                    @if (remaining == 0)
                    {
                        <div style="background:#fee2e2; color:#ef4444; padding:20px; border-radius:12px; text-align:center;">
                            <i class="fa-solid fa-circle-exclamation" style="font-size:32px; margin-bottom:12px; display:block;"></i>
                            <p style="font-weight:700; font-size:16px; margin-bottom:4px;">Kontenjan Doldu!</p>
                            <p style="font-size:13px;">Bu tur için tüm kontenjanlar dolmuştur.</p>
                            <a href="/Tour/TourList" style="display:inline-block; margin-top:16px; padding:10px 20px; background:#ef4444; color:#fff; border-radius:8px; font-weight:600; text-decoration:none;">
                                Diğer Turlara Bak
                            </a>
                        </div>
                    }
                    else
                    {
                        <form asp-action="Create" asp-controller="Booking" method="post" id="form-review">
                            <input type="hidden" name="TourID" value="@Model.TourID" />
                            <input type="hidden" name="TourTitle" value="@Model.Title" />
                            <input type="hidden" name="TourCoverImageUrl" value="@Model.CoverImageUrl" />
                            <input type="hidden" name="TourLocation" value="@Model.Location" />
                            <input type="hidden" name="TourDayCount" value="@Model.DayCount" />
                            <input type="hidden" name="TourPrice" value="@Model.Price" />

                            <h5 style="font-size:15px; font-weight:700; color:var(--primary); margin-bottom:20px; padding-bottom:10px; border-bottom:2px solid #f3f4f6;">
                                <i class="icon-user"></i> Kişisel Bilgiler
                            </h5>
                            <div class="row mb-24">
                                <div class="col-md-6">
                                    <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">Ad Soyad *</label>
                                    <fieldset class="relative input-wrap">
                                        <i class="icon-user-1-1"></i>
                                        <input type="text" name="FullName" placeholder="Adınız Soyadınız" required>
                                    </fieldset>
                                </div>
                                <div class="col-md-6">
                                    <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">E-posta *</label>
                                    <fieldset class="relative input-wrap">
                                        <i class="icon-Group-51"></i>
                                        <input type="email" name="Email" placeholder="ornek@email.com" required>
                                    </fieldset>
                                </div>
                            </div>
                            <div class="row mb-32">
                                <div class="col-md-6">
                                    <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">Telefon *</label>
                                    <fieldset class="relative input-wrap">
                                        <i class="icon-phone"></i>
                                        <input type="tel" name="Phone" placeholder="05XX XXX XX XX" required>
                                    </fieldset>
                                </div>
                            </div>

                            <h5 style="font-size:15px; font-weight:700; color:var(--primary); margin-bottom:20px; padding-bottom:10px; border-bottom:2px solid #f3f4f6;">
                                <i class="icon-destination"></i> Tur Bilgileri
                            </h5>
                            <div class="row mb-24">
                                <div class="col-md-6">
                                    <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">Tur Tarihi *</label>
                                    <fieldset class="relative input-wrap">
                                        <i class="icon-day"></i>
                                        <input type="date" name="BookingDate"
                                               min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" required
                                               style="padding-left:44px;">
                                    </fieldset>
                                </div>
                                <div class="col-md-6">
                                    <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">Katılımcı Sayısı *</label>
                                    <fieldset class="relative input-wrap">
                                        <i class="icon-user"></i>
                                        <input type="number" name="ParticipantCount" id="participantCount"
                                               min="1" max="@remaining" value="1" required
                                               style="padding-left:44px;"
                                               oninput="calculateTotal()">
                                    </fieldset>
                                    <div style="display:flex; align-items:center; gap:6px; margin-top:6px;">
                                        <div style="width:8px; height:8px; border-radius:50%; background:@capacityColor;"></div>
                                        <small style="color:@capacityColor; font-size:12px; font-weight:600;">@capacityText</small>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-32">
                                <div class="col-12">
                                    <label style="font-size:13px; font-weight:600; margin-bottom:8px; display:block;">Notlar / Özel İstekler</label>
                                    <fieldset class="relative input-wrap">
                                        <i class="icon-content"></i>
                                        <textarea name="Notes" rows="4" placeholder="Özel istekleriniz, sorularınız..."></textarea>
                                    </fieldset>
                                </div>
                            </div>

                            <div style="background:#f8fafc; border-radius:12px; padding:24px; margin-bottom:32px; border:1px solid #e5e7eb;">
                                <h5 style="font-size:15px; font-weight:700; margin-bottom:16px;">Fiyat Özeti</h5>
                                <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                                    <span style="color:#6b7280;">Tur Fiyatı</span>
                                    <span style="font-weight:600;">@Model.Price ₺</span>
                                </div>
                                <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                                    <span style="color:#6b7280;">Katılımcı Sayısı</span>
                                    <span id="participantDisplay" style="font-weight:600;">1 Kişi</span>
                                </div>
                                <div style="border-top:1px solid #e5e7eb; margin:12px 0;"></div>
                                <div style="display:flex; justify-content:space-between;">
                                    <span style="font-weight:700; font-size:16px;">Toplam</span>
                                    <span id="totalPrice" style="font-weight:800; font-size:20px; color:var(--primary);">@Model.Price ₺</span>
                                </div>
                            </div>

                            <button type="submit" class="tf-btn btn-fill" style="width:100%; padding:16px; font-size:16px;">
                                <i class="icon-Vector-7"></i> Rezervasyonu Tamamla
                            </button>
                        </form>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div style="background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 2px 20px rgba(0,0,0,.08); position:sticky; top:100px;">
                    <img src="@Model.CoverImageUrl" alt="@Model.Title"
                         style="width:100%; height:200px; object-fit:cover;">
                    <div style="padding:24px;">
                        <span style="background:var(--primary); color:#fff; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600;">
                            @Model.Badge
                        </span>
                        <h4 style="font-size:18px; font-weight:700; margin:12px 0 8px;">@Model.Title</h4>
                        <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:16px;">
                            <div style="display:flex; align-items:center; gap:8px; font-size:13px; color:#6b7280;">
                                <i class="icon-time-left" style="color:var(--primary);"></i>
                                <span>@Model.DayCount Gün</span>
                            </div>
                            <div style="display:flex; align-items:center; gap:8px; font-size:13px; color:#6b7280;">
                                <i class="icon-user" style="color:var(--primary);"></i>
                                <span>Maks. @Model.Capacity Kişi</span>
                            </div>
                            <div style="display:flex; align-items:center; gap:8px; font-size:13px; color:#6b7280;">
                                <i class="icon-18" style="color:var(--primary);"></i>
                                <span>@Model.Location</span>
                            </div>
                        </div>

                        @* Kontenjan progress bar *@
                        @{
                            int usedPercent = Model.Capacity > 0
                            ? (int)(((Model.Capacity - remaining) / (double)Model.Capacity) * 100)
                            : 100;
                        }
                        <div style="margin-bottom:16px;">
                            <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:6px;">
                                <span style="color:#6b7280;">Doluluk Oranı</span>
                                <span style="font-weight:600; color:@capacityColor;">%@usedPercent</span>
                            </div>
                            <div style="background:#f3f4f6; border-radius:99px; height:6px;">
                                <div style="background:@capacityColor; width:@(usedPercent)%; height:6px; border-radius:99px; transition:.3s;"></div>
                            </div>
                            <small style="color:@capacityColor; font-size:11px; font-weight:600; margin-top:4px; display:block;">@capacityText</small>
                        </div>

                        <div style="border-top:1px solid #f3f4f6; padding-top:16px;">
                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                <span style="font-size:13px; color:#6b7280;">Kişi Başı</span>
                                <div>
                                    <span style="font-size:20px; font-weight:800; color:var(--primary);">@Model.Price ₺</span>
                                    <del style="font-size:13px; color:#9ca3af; margin-left:6px;">@originalPrice ₺</del>
                                </div>
                            </div>
                        </div>

                        @if (Model.IncludedServices?.Any() == true)
                        {
                            <div style="margin-top:16px; border-top:1px solid #f3f4f6; padding-top:16px;">
                                <p style="font-size:13px; font-weight:700; margin-bottom:8px;">Dahil Hizmetler</p>
                                @foreach (var s in Model.IncludedServices.Take(4))
                                {
                                    <div style="display:flex; align-items:center; gap:6px; font-size:12px; color:#6b7280; margin-bottom:4px;">
                                        <i class="icon-Vector-7" style="color:#16a34a; font-size:10px;"></i>
                                        <span>@s</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    const tourPrice = @Model.Price;

    function calculateTotal() {
        const count = parseInt(document.getElementById('participantCount').value) || 1;
        const total = tourPrice * count;
        document.getElementById('totalPrice').textContent = total.toLocaleString('tr-TR') + ' ₺';
        document.getElementById('participantDisplay').textContent = count + ' Kişi';
    }
</script>